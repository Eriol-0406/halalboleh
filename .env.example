# JamAI Base Configuration
# Sign up at: https://cloud.jamaibase.com
# Create a project and get your credentials

# JamAI Base API URL (default, don't change)
NEXT_PUBLIC_JAMAI_BASE_URL=https://api.jamaibase.com

# Your JamAI Base Project ID
# Find it in: Dashboard > Settings > Project ID
# Example: proj_abc123xyz456
NEXT_PUBLIC_JAMAI_PROJECT_ID=your_project_id_here

# Your JamAI Base Personal Access Token
# Generate it in: Dashboard > Settings > API Keys > Create PAT
# Example: jamai_pat_abc123xyz456...
NEXT_PUBLIC_JAMAI_PERSONAL_ACCESS_TOKEN=your_personal_access_token_here

# Knowledge Tables (optional - for MPPHM 2020 document integration)
# Create these tables in JamAI Base dashboard if you want RAG
JAMAI_KNOWLEDGE_TABLE_MPPHM=mpphm_2020_knowledge
JAMAI_KNOWLEDGE_TABLE_IHCS=ihcs_templates

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file to .env.local
# 2. Go to https://cloud.jamaibase.com
# 3. Sign up / Log in
# 4. Create a new project
# 5. Copy your Project ID and paste above
# 6. Create a Personal Access Token
# 7. Copy the PAT and paste above
# 8. Create Action Table: ihcs_content_transformer
#    - Input columns: user_answer, company_name, business_type, chapter_number, language
#    - Output columns: formal_content, compliance_score, suggestions
# 9. (Optional) Create Knowledge Table and upload MPPHM 2020 PDF
# 10. Save this file as .env.local
# 11. Restart your dev server: npm run dev
