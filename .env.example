# ============================================
# HalalBoleh environment configuration
# Copy to .env.local and fill in your keys.
# See HANDOFF.md §2 for details.
# ============================================

# --- Grafilab (LLM / OCR / vision) ---
# Get a key from the Grafilab console: https://console.grafilab.ai
GRAFILAB_API_KEY=sk-grafilab-YOUR_KEY_HERE
GRAFILAB_BASE_URL=https://console-api.grafilab.ai/api/oai/v1

# Model roles — each is swappable independently.
# List available models: curl $GRAFILAB_BASE_URL/models -H "Authorization: Bearer $GRAFILAB_API_KEY"
AI_MODEL=grafilab/glm-5.2              # copilot agent, gap engine, drafting (needs tool calling)
AI_MODEL_FAST=grafilab/glm-5-turbo     # classification, RAG query expansion
AI_MODEL_OCR=grafilab/glm-ocr          # scanned certificates / PDFs
AI_MODEL_VISION=grafilab/qwen3-vl-plus # kitchen photos, product labels

# --- Exa (web verification + RAG knowledge ingestion) ---
# Get a key from: https://dashboard.exa.ai
EXA_API_KEY=YOUR_EXA_KEY_HERE

# --- ElevenLabs (voice: Scribe STT; TTS available) ---
# Get a key from: https://elevenlabs.io — needs speech-to-text permission
ELEVENLABS_API_KEY=sk_YOUR_ELEVENLABS_KEY_HERE
